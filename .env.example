API_ID=123456
API_HASH=your_api_hash_here

# Session file name/path for Telethon (user account login)
# Stored outside git by default (Telethon will create SESSION_NAME.session)
SESSION_NAME=.state/telethon/tvp_user

# Comma-separated list of chat IDs/usernames to allow. Empty = all chats you can access.
# Examples:
# ALLOWED_CHATS=-1001234567890,my_private_group,me
ALLOWED_CHATS=

# Temporary working directory
WORK_DIR=./work

# Persistent queue file for pending/in-progress jobs (survives reboot)
QUEUE_FILE=./.state/job_queue.json

# FFmpeg path (optional). If unset, app prefers ./vendor/ffmpeg/ffmpeg if present,
# otherwise falls back to system ffmpeg.
FFMPEG_BIN=

# Command prefix to trigger processing (message must reply to a video/file)
COMMAND_PREFIX=.vp

# Whether to delete source and output files after upload
CLEANUP=true
